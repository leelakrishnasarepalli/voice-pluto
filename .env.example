OPENAI_API_KEY=
PLUTO_INTENT_MODEL=gpt-5-mini
PLUTO_INTENT_TIMEOUT_SEC=12
PLUTO_RESEARCH_MODEL=gpt-5-mini

PLUTO_WAKEWORD_THRESHOLD=0.5
PLUTO_WAKEWORD_MODELS=pluto,hey_pluto
PLUTO_WAKEWORD_MODEL_DIR=./app/audio/models
PLUTO_WHITELIST_PATH=./config/sites.json
PLUTO_WORKFLOWS_PATH=./config/workflows.json
PLUTO_POLL_INTERVAL_SEC=30
PLUTO_TIMEZONE=America/Toronto

# Voice policy
PLUTO_DO_NOT_DISTURB=false
PLUTO_QUIET_HOURS_ENABLED=false
PLUTO_QUIET_HOURS_START=22:00
PLUTO_QUIET_HOURS_END=07:00

# Background announcer
PLUTO_ANNOUNCER_ENABLED=true
PLUTO_ANNOUNCER_REMINDER_LOOKAHEAD_MIN=15
PLUTO_ANNOUNCER_EVENT_LOOKAHEAD_MIN=30
PLUTO_ANNOUNCER_STATE_PATH=./app/state/announcer.json

# Phase 2 audio defaults
PLUTO_STT_MODEL=tiny
PLUTO_SESSION_STATE_PATH=./app/state/session.json
PLUTO_TIMERS_STATE_PATH=./app/state/timers.json
PLUTO_SILENCE_RMS_THRESHOLD=350
PLUTO_MIN_UTTERANCE_SEC=0.8
PLUTO_MAX_UTTERANCE_SEC=10
PLUTO_SILENCE_STOP_SEC=1.0
PLUTO_WAKEWORD_COOLDOWN_SEC=1.2
PLUTO_POST_ACTION_SUPPRESSION_SEC=3.0
PLUTO_DEBUG_LOG_INTERVAL_SEC=2.0
